    <!-- Help & FAQ -->
    <string name="help_title">Help &amp; FAQ</string>
    <string name="help_section_getting_started">Getting Started</string>
    <string name="help_question_create_account">How do I create an account?</string>
    <string name="help_answer_create_account">1. Click \'Create Account\' on the login screen\n2. Enter your full name and email address\n3. Set a secure password\n4. For students, provide your student ID\n5. Tap \'Sign Up\' to complete registration</string>
    <string name="help_section_browsing_filtering">Browsing &amp; Filtering</string>
    <string name="help_question_filter_listings">How do I filter listings?</string>
    <string name="help_answer_filter_listings">You can filter listings by:\n• Price range (minimum and maximum)\n• Location\n• Property type\n• Availability date\n\nTap \'Filters\' on the listings screen, adjust the fields, and tap \'Apply\'.</string>
    <string name="help_question_smart_alerts">What are Smart Alerts?</string>
    <string name="help_answer_smart_alerts">Smart Alerts notify you when new listings matching your saved preferences are posted. Save your preferred filters in the Preferences section to receive alerts.</string>
    <string name="help_section_reservations_payments">Reservations &amp; Payments</string>
    <string name="help_question_reserve_listing">How do I reserve a listing?</string>
    <string name="help_answer_reserve_listing">1. Browse and select a listing\n2. Review the details and price\n3. Tap \'Pay Deposit and Reserve\'\n4. Follow the payment instructions\n5. Receive a confirmation reference number</string>
    <string name="help_section_support">Support</string>
    <string name="help_question_contact_us">Contact Us</string>
    <string name="help_answer_contact_us">Email: support@housefinder.bw\nPhone: +267 XXX XXXX\n\nOur support team is available Monday-Friday, 9AM-5PM BOTS.</string>
