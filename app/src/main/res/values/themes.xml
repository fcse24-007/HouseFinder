<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme -->
    <style name="Base.Theme.HouseFinder" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Material Design Color System -->
        <item name="colorPrimary">@color/register_rust</item>
        <item name="colorPrimaryDark">@color/register_rust</item>
        <item name="colorAccent">@color/register_rust</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="colorSurface">@color/surface_light</item>
        <item name="colorOnSurface">@color/register_text_dark</item>
        <item name="colorError">@color/error</item>
        
        <!-- Surface Colors -->
        <item name="android:windowBackground">@color/register_cream</item>
        <item name="android:colorBackground">@color/register_cream</item>
        <item name="android:navigationBarColor">@color/register_cream</item>
        <item name="android:statusBarColor">@color/register_cream</item>

        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/register_text_dark</item>
        <item name="android:textColorSecondary">@color/register_text_light</item>
    </style>

    <style name="Theme.HouseFinder" parent="Base.Theme.HouseFinder" />
    
    <!-- Modern Button Styles -->
    <style name="Widget.HouseFinder.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/register_rust</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>
    
    <!-- Input Style -->
    <style name="Widget.HouseFinder.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/register_rust</item>
        <item name="hintEnabled">true</item>
        <item name="hintTextColor">@color/register_rust</item>
        <item name="android:textColorHint">@color/register_text_light</item>
        <item name="startIconTint">@color/register_rust</item>
        <item name="errorEnabled">true</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
    </style>

    <style name="Widget.HouseFinder.TextInputEditText" parent="Widget.MaterialComponents.TextInputEditText.OutlinedBox">
        <item name="android:paddingStart">12dp</item>
        <item name="android:textColor">@color/register_text_dark</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="Widget.HouseFinder.TextInputLayout.ExposedDropdown" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="boxStrokeColor">@color/register_rust</item>
        <item name="hintEnabled">true</item>
        <item name="hintTextColor">@color/register_rust</item>
        <item name="android:textColorHint">@color/register_text_light</item>
        <item name="startIconTint">@color/register_rust</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
    </style>

    <style name="Widget.HouseFinder.FilterTextInputLayout" parent="Widget.HouseFinder.TextInputLayout">
        <item name="boxBackgroundColor">@color/white</item>
        <item name="boxStrokeColor">@color/register_rust</item>
    </style>

    <style name="Widget.HouseFinder.FilterTextInputLayout.ExposedDropdown"
        parent="Widget.HouseFinder.TextInputLayout.ExposedDropdown">
        <item name="boxBackgroundColor">@color/white</item>
        <item name="boxStrokeColor">@color/register_rust</item>
    </style>

    <style name="Widget.HouseFinder.FilterTextInputEditText"
        parent="Widget.HouseFinder.TextInputEditText">
    </style>

    <style name="ThemeOverlay.HouseFinder.BottomSheet" parent="ThemeOverlay.MaterialComponents.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Widget.HouseFinder.BottomSheet</item>
    </style>

    <style name="Widget.HouseFinder.BottomSheet" parent="Widget.MaterialComponents.BottomSheet.Modal">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.HouseFinder.BottomSheet</item>
    </style>

    <style name="ShapeAppearance.HouseFinder.BottomSheet" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeTopRight">24dp</item>
    </style>
</resources>
